# Filling in real values later.
# .env.local gitignored — never commit.

# ==========================================
# Supabase (DB)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...your-anon-key

# ==========================================
# Prisma (DB 직접 연결 — 스키마 자동 관리용)
# ==========================================
# Supabase 대시보드 → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# ==========================================
# LLM Provider
# ==========================================
# Anthropic API key for Claude Sonnet 4.6
# Getting one at https://console.anthropic.com (set a monthly usage limit!)
ANTHROPIC_API_KEY=sk-ant-...

# ==========================================
# Frontend -> Backend
# ==========================================
# Where the Next.js frontend should call the FastAPI backend.
# Local dev: http://localhost:15501
# Production: your deployed backend URL
NEXT_PUBLIC_API_URL=http://localhost:15501
