# Filling in real values later.
# .env.local gitignored — never commit.

# ==========================================
# LLM Provider
# ==========================================
# Anthropic API key for Claude Sonnet 4.6
# Getting one at https://console.anthropic.com (set a monthly usage limit!)
ANTHROPIC_API_KEY=sk-ant-...

# ==========================================
# Frontend -> Backend
# ==========================================
# Where the Next.js frontend should call the FastAPI backend.
# Local dev: http://localhost:15501
# Production: your deployed backend URL
NEXT_PUBLIC_API_URL=http://localhost:15501

# ==========================================
# (Optional) Analytics / feature flags
# ==========================================
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_GROWTHBOOK_KEY=
